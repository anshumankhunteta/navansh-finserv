# ---------------------------------------------------------------
# Environment Variables — copy this file to .env.local to start
#   cp .env.example .env.local
#
# Public values are pre-filled. Obtain secrets from the Supabase
# project dashboard (Settings → API) or ask a team lead.
# ---------------------------------------------------------------

# Public contact info (safe to commit, already pre-filled)
NEXT_PUBLIC_PHONE_NUMBER=+1234567890
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com

# Supabase — get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Discord webhook for lead notifications (optional for local dev — omit to skip alerts)
DISCORD_WEBHOOK_URL=

# Cron job auth secret — can be any string locally, must match what GitHub Actions sends in prod
CRON_SECRET=
